# ── Core ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
API_V1_PREFIX=/api/v1
# Comma-separated allowed origins, or "*" for any (dev). In prod set to your
# frontend URL, e.g. https://flowcare.vercel.app
CORS_ORIGINS=*

# ── Database ─────────────────────────────────────────────────────────
# Docker compose sets this automatically; override for local runs.
DATABASE_URL=postgresql+psycopg://flowcare:flowcare@localhost:5432/flowcare

# ── Redis / Celery ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth (JWT) ───────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── AI (Anthropic Claude) ────────────────────────────────────────────
# Leave blank to use the deterministic template extractor fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Storage (S3-compatible; MinIO in docker compose) ─────────────────
STORAGE_BACKEND=local            # local | s3
STORAGE_LOCAL_DIR=./var/uploads
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=flowcare-referrals
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── OCR ──────────────────────────────────────────────────────────────
OCR_BACKEND=tesseract            # tesseract | textract
TESSERACT_CMD=                   # leave blank to use PATH

# ── Notifications: Twilio SMS ────────────────────────────────────────
# Leave blank to use the logged mock sender. When ACCOUNT_SID + AUTH_TOKEN
# and one of FROM_NUMBER / MESSAGING_SERVICE_SID are set, SMS notifications
# dispatch through the real Twilio Messages API.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=               # E.164, e.g. +14155552671
TWILIO_MESSAGING_SERVICE_SID=     # optional alternative to FROM_NUMBER

# ── Email: SMTP (verification + password reset) ─────────────────────
# Leave SMTP_HOST blank to use the logged mock sender. Examples:
#   Gmail:    smtp.gmail.com:587  (SMTP_USER = your address, SMTP_PASSWORD = app password)
#   Mailtrap: sandbox.smtp.mailtrap.io:587
#   SendGrid: smtp.sendgrid.net:587  (SMTP_USER=apikey, SMTP_PASSWORD=<key>)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=FlowCare AI <no-reply@flowcare.ai>
SMTP_USE_TLS=true
FRONTEND_BASE_URL=http://localhost:3000

# ── Seed admin ───────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@flowcare.ai
FIRST_ADMIN_PASSWORD=admin12345
